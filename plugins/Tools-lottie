import { buildLottieSticker } from "../../src/index.js"; 
import { downloadMediaMessage } from "@whiskeysockets/baileys";
import { resolve, dirname } from "path";
import { readFileSync, unlinkSync } from "fs";
import { fileURLToPath } from "url";

const __dirname = dirname(fileURLToPath(import.meta.url));

export default {
  command: ["lottie", "lt"],
  category: "stickers",
  run: async (client, m, args, command, text, prefix) => {

    const quoted = m.quoted;
    const imageMsg = quoted?.message?.imageMessage;

    if (!imageMsg) {
      return client.sendMessage(m.chat, 
        { text: "✐ Responde a una imagen con el comando" }, 
        { quoted: m }
      );
    }

    try {
      const buffer = await downloadMediaMessage(quoted, "buffer", {});

      const outputPath = resolve(__dirname, `../../lottie_temp_${Date.now()}.was`);

      await buildLottieSticker({
        baseFolder: resolve(__dirname, "../../src/exemple"),
        buffer: buffer,
        mime: imageMsg.mimetype || "image/jpeg",
        output: outputPath
      });

      await client.sendMessage(m.chat, {
        sticker: readFileSync(outputPath),
        mimetype: "application/was",
        isAnimated: true,
        isLottie: true
      }, { quoted: m });

      unlinkSync(outputPath);

    } catch (err) {
      console.error("Error lottie:", err);
      await client.sendMessage(m.chat, 
        { text: `Error: ${err.message}` }, 
        { quoted: m }
      );
    }
  },
};
